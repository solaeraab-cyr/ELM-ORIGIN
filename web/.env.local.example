# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Sentry — error tracking (leave blank to disable)
NEXT_PUBLIC_SENTRY_DSN=

# PostHog — product analytics (leave blank to disable)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Cashfree — payments (leave blank to use mock payment mode)
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=TEST

# Resend — transactional email (leave blank to skip email sending silently)
RESEND_API_KEY=

# LiveKit — video calling (leave blank to show "coming soon" placeholder)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=
